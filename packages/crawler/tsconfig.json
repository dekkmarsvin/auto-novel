{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "strict": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "ES2021"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
